## Phase 2: CLI Integration

### File: `rgen/cli.py` modification

```python
def _cmd_suggest_scenarios(args: argparse.Namespace) -> int:
    """Suggest new scenarios from intervention history."""
    from rgen.scenario_clusterer import ScenarioClusterer
    from rgen.interventions import InterventionStore

    store = InterventionStore()
    clusterer = ScenarioClusterer(store, min_cluster_size=3)
    suggestions = clusterer.suggest_scenarios()

    if not suggestions:
        print("No new scenario suggestions at this time.")
        return 0

    print(f"\n🎯 Suggested Scenarios ({len(suggestions)} candidates):\n")
    for idx, sugg in enumerate(suggestions, 1):
        print(f"{idx}. {sugg['suggested_scenario']}")
        print(f"   Confidence: {sugg['confidence']:.0%}")
        print(f"   Size: {sugg['size']} queries")
        print(f"   Keywords: {', '.join(sugg['keywords'][:5])}")
        print()

    store.close()
    return 0
```

### Parser modification:

```python
mode.add_argument("--suggest-scenarios", dest="suggest_scenarios", action="store_true",
                  help="Suggest new scenarios from intervention history")
```

### Usage:

```bash
rgen --suggest-scenarios
# OR
rgen --suggest-scenarios --dry-run  # preview only
```

