## Phase 1: ScenarioClusterer

### File: `rgen/scenario_clusterer.py`

```python
class ScenarioClusterer:
    """
    Detect similar queries in intervention history.

    Suggests new scenarios based on unmatched query patterns.
    """

    def __init__(self, store: InterventionStore, min_cluster_size: int = 3):
        """Initialize clusterer with intervention store."""
        self.store = store
        self.min_cluster_size = min_cluster_size

    def load_interventions(self, limit: int = 100) -> list[dict]:
        """Load recent interventions from DB."""

    def vectorize_query(self, query: str) -> list[float]:
        """Convert query to vector (TF-IDF or keyword-based)."""

    def cluster_queries(self, queries: list[str]) -> dict[int, list[str]]:
        """Cluster similar queries using cosine similarity."""

    def suggest_scenarios(self) -> list[dict]:
        """
        Returns candidate scenarios:
        [
          {
            "cluster_id": 0,
            "queries": ["optimize query", "improve performance"],
            "keywords": ["optimize", "performance"],
            "suggested_scenario": "query_optimization",
            "confidence": 0.87,
            "size": 7
          },
          ...
        ]
        """
```

