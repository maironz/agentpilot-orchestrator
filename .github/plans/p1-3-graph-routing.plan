## Routing Map Update Example

```json
{
  "auth_fix": {
    "agent": "backend",
    "keywords": ["auth", "login", "security"],
    "dependencies": [],  ← No secondary agents
    "files": [".github/esperti/esperto_backend.md"],
    "context": "Authentication issues"
  },
  "full_deployment": {
    "agent": "backend",
    "keywords": ["deploy", "fix", "production"],
    "dependencies": ["devops"],  ← ← ← NEW: cascade to devops
    "files": [".github/esperti/esperto_backend.md"],
    "context": "Full stack deployment"
  },
  "database_migration": {
    "agent": "backend",
    "keywords": ["migrate", "schema", "alter"],
    "dependencies": ["devops", "db_admin"],  ← Multiple secondary
    "files": [".github/esperti/esperto_backend.md"],
    "context": "Database schema changes"
  }
}
```

