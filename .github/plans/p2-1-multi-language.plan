## Implementation Phases

### Phase 1: Language Detection (Day 1)

**Files**: `rgen/language_detector.py` (80-120 lines)

```python
class LanguageDetector:
    SUPPORTED_LANGS = ["it", "en", "es", "fr"]
    DEFAULT_LANG = "en"

    def detect_from_metadata(self, metadata: dict) -> str:
        """
        Extract language from metadata.json.

        metadata = {
            "language": "it",  ← Look here
            "project_name": "...",
            ...
        }
        """
        lang = metadata.get("language", "").lower()
        if lang in self.SUPPORTED_LANGS:
            return lang
        return self.DEFAULT_LANG

    def detect_from_readme(self, readme_path: str) -> str:
        """
        Heuristic: scan README first lines for language patterns.

        - "# " + Italian keywords → it
        - "# " + Spanish keywords → es
        - etc.
        """
        try:
            with open(readme_path, "r", encoding="utf-8") as f:
                content = f.read(500).lower()

            # Italian markers
            if any(kw in content for kw in ["progetto", "descrizione", "requisiti"]):
                return "it"

            # Spanish markers
            if any(kw in content for kw in ["proyecto", "descripción", "requisitos"]):
                return "es"

            # French markers
            if any(kw in content for kw in ["projet", "description", "exigences"]):
                return "fr"

            return "en"  # default
        except Exception:
            return "en"

    def detect(self, metadata: dict, readme_path: str | None = None) -> str:
        """
        Detect language with priority: metadata > readme > default.
        """
        lang = self.detect_from_metadata(metadata)
        if lang != self.DEFAULT_LANG:
            return lang

        if readme_path:
            lang = self.detect_from_readme(readme_path)
            if lang != self.DEFAULT_LANG:
                return lang

        return self.DEFAULT_LANG
```

