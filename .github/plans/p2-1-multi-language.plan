### Phase 2: Template Localization (Day 1-2)

**Files**: `rgen/template_localizer.py` (150-200 lines)

```python
class TemplateLocalizer:
    LANGUAGE_METADATA = {
        "it": {
            "name": "Italian",
            "tone": "Professionale, formale",
            "examples_prefix": "Esempi:",
        },
        "en": {
            "name": "English",
            "tone": "Professional, concise",
            "examples_prefix": "Examples:",
        },
        "es": {
            "name": "Spanish",
            "tone": "Profesional, formal",
            "examples_prefix": "Ejemplos:",
        },
        "fr": {
            "name": "French",
            "tone": "Professionnel, formel",
            "examples_prefix": "Exemples:",
        },
    }

    def __init__(self, language: str, fallback: str = "en"):
        self.language = language if language in self.LANGUAGE_METADATA else fallback
        self.fallback = fallback

    def load_template(self, pattern: str, agent_role: str) -> str:
        """
        Load template in target language.

        priority:
        1. knowledge_base/<pattern>/i18n/<lang>/esperti/esperto_<role>.template.md
        2. knowledge_base/<pattern>/i18n/en/esperti/esperto_<role>.template.md  (fallback)
        """
        from pathlib import Path

        kb_root = Path("knowledge_base") / pattern / "i18n"

        # Try target language
        target_path = kb_root / self.language / "esperti" / f"esperto_{agent_role}.template.md"
        if target_path.exists():
            return target_path.read_text(encoding="utf-8")

        # Fallback to English
        fallback_path = kb_root / self.fallback / "esperti" / f"esperto_{agent_role}.template.md"
        if fallback_path.exists():
            return fallback_path.read_text(encoding="utf-8")

        raise FileNotFoundError(
            f"Template not found: {agent_role} for pattern {pattern} "
            f"(tried: {self.language}, {self.fallback})"
        )

    def substitute_language_context(self, template: str, vars: dict) -> str:
        """
        Substitute language-specific variables in template.

        {{LANGUAGE}} → "Italian"
        {{TONE}} → "Professionale, formale"
        {{EXAMPLES_PREFIX}} → "Esempi:"
        """
        metadata = self.LANGUAGE_METADATA[self.language]
        localized_vars = {
            **vars,
            "LANGUAGE": metadata["name"],
            "TONE": metadata["tone"],
            "EXAMPLES_PREFIX": metadata["examples_prefix"],
        }

        result = template
        for var, value in localized_vars.items():
            result = result.replace(f"{{{{{var}}}}}", str(value))

        return result
```

